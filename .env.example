# Copy this file to `.env` and fill in your Supabase project values.
# Vars must be prefixed with EXPO_PUBLIC_ to be readable in the app at runtime.
# Find these in your Supabase dashboard: Project Settings -> API.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Android-only: Google Maps key for react-native-maps (see app.config.js).
# Not EXPO_PUBLIC_ — it's a build-time native config value, not read at runtime.
# iOS uses Apple Maps and needs no key. Leave blank until you do an Android build.
GOOGLE_MAPS_ANDROID_KEY=
