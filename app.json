{
  "expo": {
    "name": "seoul-popups",
    "slug": "seoul-popups",
    "version": "1.0.0",
    "scheme": "seoulpopups",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mgnradar.seoulpopups"
    },
    "android": {
      "package": "com.mgnradar.seoulpopups",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Seoul Popups to use your location to show pop-ups near you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
